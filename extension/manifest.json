{
  "manifest_version": 3,
  "name": "attend",
  "version": "0.1.0",
  "description": "In-browser enforcement for attend rules — path-level blocking and friction.",
  "permissions": ["storage", "alarms"],
  "host_permissions": [
    "http://127.0.0.1:7723/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["match.js", "content.js"],
      "css": ["overlay.css"],
      "run_at": "document_start",
      "all_frames": false
    }
  ]
}
